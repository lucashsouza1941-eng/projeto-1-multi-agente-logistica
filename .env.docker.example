# Passo 1: copiar para .env.docker (obrigatório para docker compose)
#   Windows: copy .env.docker.example .env.docker
#   Unix:    cp .env.docker.example .env.docker
# Passo 2: ajuste segredos (JWT_SECRET, POSTGRES_PASSWORD em produção).
# Passo 3: docker compose up -d
#
# -----------------------------------------------------------------------------
# PostgreSQL (serviço postgres + URL da API)
# -----------------------------------------------------------------------------
POSTGRES_USER=logiagent
POSTGRES_PASSWORD=logiagent
POSTGRES_DB=logiagent
DATABASE_URL=postgresql://logiagent:logiagent@postgres:5432/logiagent

# -----------------------------------------------------------------------------
# Redis (BullMQ + health da API)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# API (NestJS) — apps/api
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3001
JWT_SECRET=altere-este-segredo-minimo-32-caracteres-producao
# Opcional: triagem/relatórios com LLM
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# CORS: origens do front (navegador). Com compose expondo web em localhost:
FRONTEND_URL=http://localhost:3000
# Produção atrás de domínio:
# FRONTEND_URL=https://app.exemplo.com

# -----------------------------------------------------------------------------
# Web (Next.js) — build-time + runtime onde aplicável
# -----------------------------------------------------------------------------
# Base da API no bundle cliente (lib/api.ts). No Docker, o navegador não resolve
# "api"; use http://localhost:3001 e reconstrua a imagem web se precisar de fetch
# direto no browser. Registro/login usam rotas /api/* com INTERNAL_API_URL.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Obrigatório no servidor Next (Docker): chamada à Nest pela rede compose.
INTERNAL_API_URL=http://api:3001

# -----------------------------------------------------------------------------
# Pós-subida (migrações)
# -----------------------------------------------------------------------------
# docker compose --env-file .env.docker exec api sh -c "pnpm exec prisma migrate deploy"
