# Copie para .env.local na raiz do repositório.

# URL pública da API Nest (browser + fallback). Sem barra no final.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Segredos da API (apps/api/.env) — mínimo 32 caracteres aleatórios.
# JWT_SECRET assina access tokens; REFRESH_TOKEN_SECRET protege refresh tokens.
JWT_SECRET=altere-este-jwt-secret-com-no-minimo-32-caracteres
REFRESH_TOKEN_SECRET=altere-este-refresh-secret-com-no-minimo-32-caracteres

# Opcional: URL da API só no servidor Next (rotas /api/auth, /api/backend, /api/log-error).
# Útil em Docker/rede interna quando difere do host que o navegador usa.
# INTERNAL_API_URL=http://localhost:3001

# Opcional — mesmo webhook que a API (documentado em apps/api/.env.example)
# ALERT_WEBHOOK_URL=
