# Copie para apps/api/.env e ajuste.

NODE_ENV=development
PORT=3001

# PostgreSQL (Prisma — obrigatório em runtime)
DATABASE_URL=postgresql://logiagent:logiagent@localhost:5433/logiagent

# Redis (BullMQ, health check)
REDIS_URL=redis://localhost:6379

# JWT (mínimo 32 caracteres) e segredo de refresh — obrigatórios para arranque da API
JWT_SECRET=altere-este-jwt-com-pelo-menos-32-caracteres!!
REFRESH_TOKEN_SECRET=altere-este-refresh-com-pelo-menos-32-chars!!
# Opcional: GET /admin/* com header x-admin-key
# ADMIN_INTERNAL_KEY=

# CORS: origem do Next (produção: URL(s) reais; pode listar várias separadas por vírgula no código)
FRONTEND_URL=http://localhost:3000

# Opcional — webhook genérico (Slack, etc.) para alertas operacionais
# ALERT_WEBHOOK_URL=

# Opcional — integrações LangChain / OpenAI
OPENAI_API_KEY=

# Fluxo: POST /auth/register (uma vez) → POST /auth/login.
# Demais rotas exigem header Authorization: Bearer <JWT>.
